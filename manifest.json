{
	"manifest_version": 2,
	"version": "0.1",
	"name": "Onion Button",
	"description": "An ettempt to make an addon to manage your TOR installation through control port.",
	"browser_specific_settings": {
		"gecko": {
			"id": "torbutton@example.com",
			"strict_min_version": "48.0"
		}
	},
	"browser_action": {
		"default_icon": {
			"16": "img/tor.svg",
			"32": "img/tor.svg"
		},
		"default_title": "TOR Control",
		"default_popup":"popup/popup-control.html"
	},
	"permissions": ["storage"],
	"icons": {
		"16": "img/tor.svg",
		"32": "img/tor.svg",
		"48": "img/tor.svg",
		"64": "img/tor.svg",
		"128": "img/tor.svg"
	}
}